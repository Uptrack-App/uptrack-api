# Uptrack Environment Variables Example
# Copy this file to .env and fill in your values for production deployment

# ============================================================================
# DATABASE CONFIGURATION - Multi-Repo Setup
# ============================================================================

# PostgreSQL Primary (AppRepo) - User data, monitors, incidents, alerts
DATABASE_URL=postgresql://uptrack:PASSWORD@DATABASE_HOST:5432/uptrack_prod?search_path=app,public

# PostgreSQL Oban Repo - Oban job queue
OBAN_DATABASE_URL=postgresql://uptrack:PASSWORD@DATABASE_HOST:5432/uptrack_prod?search_path=oban,public

# PostgreSQL Results Repo - Monitoring data and check results
RESULTS_DATABASE_URL=postgresql://uptrack:PASSWORD@DATABASE_HOST:5432/uptrack_prod?search_path=results,public

# ============================================================================
# CONNECTION POOL CONFIGURATION - Per-Repo Sizing
# ============================================================================
# Each repo has different workload characteristics:
#
# APP_POOL_SIZE: Light OLTP (users, configs, incidents)
#   - Typical range: 8-15 connections
#   - Germany primary: 15, India replica: 10
#
# OBAN_POOL_SIZE: High job throughput (monitor checks)
#   - Typical range: 20-40 connections
#   - Germany primary: 30, India replica: 25
#
# RESULTS_POOL_SIZE: Batch inserts (monitoring results)
#   - Typical range: 12-20 connections
#   - Germany primary: 20, India replica: 15

APP_POOL_SIZE=10
OBAN_POOL_SIZE=20
RESULTS_POOL_SIZE=15

# ============================================================================
# ECTO CONFIGURATION
# ============================================================================
# IPv6 support (set to "true" or "1" to enable)
ECTO_IPV6=false

# ============================================================================
# OBAN JOB QUEUE CONFIGURATION
# ============================================================================

# Node name for Oban cluster identification
OBAN_NODE_NAME=uptrack-node-1

# Job concurrency per queue
OBAN_CHECKS_CONCURRENCY=50
OBAN_WEBHOOKS_CONCURRENCY=10
OBAN_INCIDENTS_CONCURRENCY=5

# ============================================================================
# CLICKHOUSE CONFIGURATION - Time-Series Database
# ============================================================================
# ClickHouse is used for time-series monitoring data (via ResilientWriter)
# Separate from PostgreSQL for optimal performance

CLICKHOUSE_HOST=clickhouse.internal
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default

# ============================================================================
# PHOENIX ENDPOINT CONFIGURATION
# ============================================================================

# Server settings
PHX_HOST=example.com
PHX_SERVER=true
PORT=4000

# Secret key for signing cookies and tokens
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here

# ============================================================================
# MONITORING NODE INFORMATION
# ============================================================================

# Geographic region for this node
NODE_REGION=eu-central

# Node name/identifier
NODE_NAME=germany

# ============================================================================
# DNS CLUSTER CONFIGURATION
# ============================================================================
# Optional: For cluster discovery via DNS
DNS_CLUSTER_QUERY=uptrack.local

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
#
# Germany Node (PostgreSQL PRIMARY):
#   export APP_POOL_SIZE=15
#   export OBAN_POOL_SIZE=30
#   export RESULTS_POOL_SIZE=20
#   export OBAN_NODE_NAME=germany
#   export NODE_REGION=eu-central
#
# India Strong Node (PostgreSQL REPLICA):
#   export APP_POOL_SIZE=10
#   export OBAN_POOL_SIZE=25
#   export RESULTS_POOL_SIZE=15
#   export OBAN_NODE_NAME=india-strong
#   export NODE_REGION=ap-south
#
# Canada Node (App-only):
#   export APP_POOL_SIZE=8
#   export OBAN_POOL_SIZE=20
#   export RESULTS_POOL_SIZE=12
#   export OBAN_NODE_NAME=canada
#   export NODE_REGION=na-east
#
# Use Tailscale for private inter-node communication
# Use SSL certificates for external HTTPS
