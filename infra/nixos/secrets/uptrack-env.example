# Uptrack Environment Variables
# Copy this to uptrack-env and fill in real values
# Then encrypt with: nix develop --command agenix -e uptrack-env.age

# Phoenix Configuration
SECRET_KEY_BASE=generate_with_mix_phx.gen.secret_or_openssl_rand
LIVE_VIEW_SIGNING_SALT=generate_32_char_random_string

# Database Configuration
DATABASE_URL=ecto://uptrack:YOUR_DB_PASSWORD@localhost:5432/uptrack
RESULTS_DATABASE_URL=ecto://uptrack:YOUR_DB_PASSWORD@localhost:5432/uptrack_results
OBAN_DATABASE_URL=ecto://uptrack:YOUR_DB_PASSWORD@localhost:5432/uptrack

# ClickHouse Configuration
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=YOUR_CLICKHOUSE_PASSWORD
CLICKHOUSE_DATABASE=uptrack

# Application Configuration
PHX_HOST=uptrack.example.com
PORT=4000
PHX_SERVER=true
MIX_ENV=prod

# Email delivery
# Options: smtp_fleet (self-hosted Stalwart), brevo, mailgun, postmark, sendgrid
# SMTP_FALLBACK_HOST is set per-node in NixOS config (not here) because it differs per node.
MAILER_ADAPTER=smtp_fleet
SMTP_HOST=127.0.0.1
SMTP_PORT=587
# SMTP_USERNAME=          # leave unset if Stalwart accepts unauthenticated relay from localhost
# SMTP_PASSWORD=

# OAuth (if needed)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ACME/SSL
ACME_EMAIL=your@email.com
