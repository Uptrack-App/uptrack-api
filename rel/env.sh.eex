#!/bin/sh

# Long names for Erlang distribution (cross-node clustering over Tailscale)
export RELEASE_DISTRIBUTION=name

# Resolve Tailscale IP for node name
# Use full path since systemd may have restricted PATH
TS_BIN="/run/current-system/sw/bin/tailscale"
if [ -x "$TS_BIN" ]; then
  TS_IP=$("$TS_BIN" ip -4 2>/dev/null)
fi

if [ -n "$TS_IP" ]; then
  export RELEASE_NODE="uptrack@${TS_IP}"
else
  export RELEASE_NODE="uptrack@127.0.0.1"
fi
