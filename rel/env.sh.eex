#!/bin/sh

# Long names for Erlang distribution (cross-node clustering over Tailscale)
export RELEASE_DISTRIBUTION=name

# Resolve Tailscale FQDN for node name
if command -v tailscale >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
  TS_HOSTNAME=$(tailscale status --self --json 2>/dev/null | jq -r '.Self.DNSName' | sed 's/\.$//')
fi

if [ -n "$TS_HOSTNAME" ]; then
  export RELEASE_NODE="uptrack@${TS_HOSTNAME}"
else
  export RELEASE_NODE="uptrack@$(hostname -f)"
fi
