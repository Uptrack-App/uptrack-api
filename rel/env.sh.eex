#!/bin/sh

# Long names for Erlang distribution (cross-node clustering over Tailscale)
export RELEASE_DISTRIBUTION=name

# Resolve Tailscale IP for node name (more reliable than DNS hostname)
if command -v tailscale >/dev/null 2>&1; then
  TS_IP=$(tailscale ip -4 2>/dev/null)
fi

if [ -n "$TS_IP" ]; then
  export RELEASE_NODE="uptrack@${TS_IP}"
else
  export RELEASE_NODE="uptrack@127.0.0.1"
fi
